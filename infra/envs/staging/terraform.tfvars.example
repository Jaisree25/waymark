# Copy to terraform.tfvars (gitignored) or pass via TF_VAR_*. Secrets belong in Secret Manager.
project      = "fsd-benchmark-staging"
region       = "us-west1"
ingest_image = "us-west1-docker.pkg.dev/fsd-benchmark-staging/fsd/ingest:m1"

# db_password — DO NOT put here. Use TF_VAR_db_password / Secret Manager. DATABASE_URL is derived
# from the Cloud SQL instance by the stack module, so you don't set it.

# Only needed when enable_aggregate = true (A's nightly image is published):
# aggregate_image = "us-west1-docker.pkg.dev/fsd-benchmark-staging/fsd/aggregate:m1"
# runner_sa       = "fsd-runner@fsd-benchmark-staging.iam.gserviceaccount.com"
